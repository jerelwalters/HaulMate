# Copy to one of the ignored local files:
# - supabase/.env.local
# - supabase/.env.development.local
# - supabase/.env.pilot.local
#
# Public client values only. Never put service role keys, database passwords,
# JWT secrets, OAuth provider secrets, or storage access secrets in this file.

HAULMATE_SUPABASE_ENV=local
HAULMATE_SUPABASE_PROJECT_REF=local
HAULMATE_SUPABASE_URL=http://127.0.0.1:54321
HAULMATE_SUPABASE_PUBLIC_KEY=<copy-publishable-or-anon-public-key>
